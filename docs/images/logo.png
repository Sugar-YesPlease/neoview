<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6"/>
      <stop offset="100%" style="stop-color:#6366f1"/>
    </linearGradient>
  </defs>
  <!-- 圆角方块背景，与导航栏logo一致 -->
  <rect width="64" height="64" rx="14" ry="14" fill="url(#bg)"/>
  <!-- 摄像头图标，与导航栏SVG路径保持一致 -->
  <!-- 屏幕主体部分：圆角矩形 -->
  <rect x="8" y="20" width="34" height="24" rx="5" ry="5" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- 摄像头镜头三角形 -->
  <path d="M42 27l14 -7v24l-14 -7z" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
